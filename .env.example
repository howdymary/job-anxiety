# Job Anxiety local environment template
# Copy to `.env` for docker-compose based local development.

APP_NAME=Job Anxiety
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
NODE_ENV=development

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-long-random-secret

# Backend
DATABASE_URL=postgresql://job_anxiety:job_anxiety_password@localhost:5432/job_anxiety
REDIS_URL=redis://:job_anxiety_redis_password@localhost:6379
API_KEY_SECRET=replace-me-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_REDIS_URL=redis://:job_anxiety_redis_password@localhost:6379

# Scraper
SCRAPER_USER_AGENT=JobAnxietyBot/1.0 (+https://jobanxiety.ai/bot; jobs@jobanxiety.ai)
SCRAPER_DELAY_SECONDS=1.0
SCRAPER_MAX_RETRIES=3
ROBOTS_CACHE_TTL_SECONDS=86400

# Enrichment
CRUNCHBASE_API_KEY=
PITCHBOOK_API_KEY=
FORTUNE500_JSON_PATH=./scraper/data/fortune500.json
COMPANY_OVERRIDES_PATH=./scraper/data/company_overrides.json

# Email / newsletter
EMAIL_PROVIDER=buttondown
BUTTONDOWN_API_KEY=
BUTTONDOWN_EMAIL_STATUS=draft
JOBANXIETY_SITE_URL=http://localhost:3000
EMAIL_FROM=The Market Brief <brief@jobanxiety.ai>
EMAIL_REPLY_TO=hello@jobanxiety.ai
EMAIL_DOUBLE_OPT_IN=true

# Observability
SENTRY_DSN=
PLAUSIBLE_DOMAIN=
