# Reframe local environment template
# Copy to `.env` for docker-compose based local development.

APP_NAME=Reframe
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
NODE_ENV=development

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-long-random-secret

# Backend
DATABASE_URL=postgresql://reframe:reframe_password@localhost:5432/reframe
REDIS_URL=redis://:reframe_redis_password@localhost:6379
API_KEY_SECRET=replace-me-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_REDIS_URL=redis://:reframe_redis_password@localhost:6379

# Scraper
SCRAPER_USER_AGENT=ReframeBot/1.0 (+https://reframe.jobs/bot; jobs@reframe.jobs)
SCRAPER_DELAY_SECONDS=1.0
SCRAPER_MAX_RETRIES=3
ROBOTS_CACHE_TTL_SECONDS=86400

# Enrichment
CRUNCHBASE_API_KEY=
PITCHBOOK_API_KEY=
FORTUNE500_JSON_PATH=./scraper/data/fortune500.json
COMPANY_OVERRIDES_PATH=./scraper/data/company_overrides.json

# Email / subscriber flow
EMAIL_PROVIDER=
EMAIL_FROM=Reframe <hello@reframe.jobs>
EMAIL_REPLY_TO=support@reframe.jobs
EMAIL_DOUBLE_OPT_IN=true

# Observability
SENTRY_DSN=
PLAUSIBLE_DOMAIN=
